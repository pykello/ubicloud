#!/bin/env ruby
# frozen_string_literal: true

require "json"
require_relative "../lib/storage_volume"

unless (vm_name = ARGV.shift)
  puts "expected vm_name as argument"
  exit 1
end

params = JSON.parse($stdin.read)

sv = StorageVolume.new(vm_name, params)
sv.vhost_backend_dump_metadata(params["key_wrapping_secrets"])
